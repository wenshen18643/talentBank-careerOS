# Kimi API. Leave KIMI_API_KEY blank to run in deterministic offline-stub mode.
#
# Kimi-for-Coding plan (key from kimi.com):
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-for-coding
KIMI_TEMPERATURE=1
KIMI_USER_AGENT=claude-code/1.0
#
# Moonshot platform key instead? Use:
#   KIMI_BASE_URL=https://api.moonshot.ai/v1   (or https://api.moonshot.cn/v1)
#   KIMI_MODEL=kimi-k2-0711-preview
#   KIMI_TEMPERATURE=0.3   (and KIMI_USER_AGENT can be left default)

# Optional request timeout for the thinking model (ms).
KIMI_TIMEOUT_MS=60000

# Secret used to sign session cookies. Any long random string in dev.
SESSION_SECRET=dev-only-insecure-change-me

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
